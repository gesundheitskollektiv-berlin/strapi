{
  "kind": "collectionType",
  "collectionName": "geko_announcements",
  "info": {
    "singularName": "geko-announcement",
    "pluralName": "geko-announcements",
    "displayName": "Geko - Announcement",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "publish_date": {
      "type": "datetime"
    },
    "is_event": {
      "type": "boolean",
      "default": false
    },
    "event_date": {
      "type": "datetime",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_event"
            },
            true
          ]
        }
      }
    },
    "when_text": {
      "type": "text",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_event"
            },
            true
          ]
        }
      }
    },
    "where_address": {
      "type": "text",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_event"
            },
            true
          ]
        }
      }
    },
    "event_host": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_event"
            },
            true
          ]
        }
      }
    },
    "teaser_text": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    }
  }
}
